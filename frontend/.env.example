# In local dev, leave these unset — Vite's proxy (vite.config.js) handles /api and /uploads.
# In production (frontend and backend on different domains/hosts), set these to your
# deployed backend's URL, e.g.:
VITE_API_URL=https://your-backend.onrender.com/api
VITE_SOCKET_URL=https://your-backend.onrender.com
